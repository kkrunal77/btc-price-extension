{
  "manifest_version": 3,
  "name": "Markets Overview",
  "version": "1.0",
  "description": "Real-time multi-asset market dashboard with interactive candlestick charts for Bitcoin, Gold, Nifty 50, and Silver.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Markets Overview",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.coingecko.com/*",
    "https://query1.finance.yahoo.com/*",
    "https://query2.finance.yahoo.com/*",
    "https://api.allorigins.win/*"
  ]
}
